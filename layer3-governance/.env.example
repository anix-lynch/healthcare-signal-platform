# Copy to .env and fill from ~/.config/secrets/global.env
# NEVER commit .env

# GCP
GOOGLE_APPLICATION_CREDENTIALS=~/.config/secrets/gcp-adc.json
GCP_PROJECT_ID=your-genai-project
GCP_LOCATION=us-central1

# Anthropic (keep inert — use subscription CLI for general work)
# ANTHROPIC_API_KEY=...  # only activate for batch runs

# Microsoft Fabric (for Step 2b — manual b-turn, no env var needed)
# Sign into portal.fabric.microsoft.com with anixlynch@gmail.com trial

# Optional
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
